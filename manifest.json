{
  "manifest_version": 3,
  "name": "МЭШ — Помощник учителя",
  "description": "Подсветка учеников с малым количеством оценок, анализ пропусков и экспорт в Excel в журнале school.mos.ru.",
  "version": "1.3.0",
  "host_permissions": [
    "https://school.mos.ru/*"
  ],
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/marks-api-hook.js"
      ],
      "matches": [
        "https://school.mos.ru/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://school.mos.ru/*"
      ],
      "js": [
        "src/marks-api-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://school.mos.ru/*"
      ],
      "js": [
        "src/panel-shell.js",
        "src/hybrid-counter.js",
        "src/final-control.js",
        "src/highlight-toggle.js",
        "src/clean-panel.js",
        "src/final-summary-guard.js",
        "src/selection-export.js",
        "src/class-data.js",
        "src/class-workbook.js",
        "src/class-summary-sheet.js",
        "src/class-subject-sheet.js",
        "src/class-export.js",
        "src/class-workbook-export.js"
      ],
      "css": [
        "src/panel.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
